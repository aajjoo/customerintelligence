# Kopieren nach .env und Werte eintragen. Keine Secrets committen.
DATABASE_URL="postgresql://user:passwort@host/marktradar?sslmode=require"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="zufallswert-z-b-openssl-rand-hex-32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ALLOWED_EMAIL_DOMAIN="netural.com"

# Pipeline (Etappe 3)
ANTHROPIC_API_KEY=""
# Schützt den Cron-Endpunkt /api/pipeline/run (Vercel sendet ihn als Bearer-Token)
CRON_SECRET=""
# Optional: anderes Claude-Modell für das Scoring (Default: claude-opus-4-8)
# CLAUDE_MODEL="claude-haiku-4-5"

# Integrationen (Etappe 7) – optional, Features sind ohne Konfiguration deaktiviert
# Slack Incoming Webhook für Pipeline-Zusammenfassungen und Workflow-Ausspielung
SLACK_WEBHOOK_URL=""
# HubSpot Private-App-Token für die Opportunity-Übergabe als Deal
HUBSPOT_TOKEN=""
# Jira/Confluence Cloud (Projekte-Bereich): Import laufender Projekte,
# Ticket-Statistik und Material für die Projekt-Einschätzung
JIRA_BASE_URL=""
JIRA_EMAIL=""
JIRA_API_TOKEN=""
# Optional: schnelleres Modell nur für das Signal-Scoring der Pipeline
# SCORING_MODEL="claude-haiku-4-5"
# Optional: Modell für die automatische Web-Recherche (Default: claude-sonnet-5 –
# Opus ist mit Websuche zu langsam für das Vercel-Funktionslimit von 300 s)
# RESEARCH_MODEL="claude-sonnet-5"
